{
  "identifier": "default",
  "description": "Default capabilities for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:allow-save",
    "dialog:allow-open",
    "fs:allow-write",
    "fs:allow-read",
    "fs:allow-exists",
    "fs:allow-mkdir",
    "fs:allow-remove",
    "dialog:allow-message",
    "dialog:allow-ask"
  ]
}
